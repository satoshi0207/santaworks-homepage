# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# local notes (not for publishing)
/notes/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# wrangler dev のローカル状態
/.wrangler/

# プロジェクト内部ドキュメント（リポジトリには含めない）
/CLAUDE.md
# 手元用の料金目安テンプレ（社内メモ・公開しない）
/料金目安-社内メモ.md
# 手元用の見積書・契約書テンプレ（社内メモ・公開しない）
/契約書テンプレ-社内メモ.md
